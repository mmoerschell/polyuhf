#include <stddef.h>
#include <stdint.h>
#include <stdio.h>
#include <stdlib.h>
{% if settings.platform == "avx2" %}
#include "tsc_x86.h"
{% else %}
#include <time.h>
{% endif %}

#include "datastructures.h"
#include "field_config.h"
#include "{{module_name}}.h"

{% if settings.platform != "avx2" %}
#define PROC_FREQUENCY {{ settings.target.frequency_ghz }}
{% endif %}
#define SEED {{ settings.target.perf_seed }}
#define NUM_WARMUP_ROUNDS {{ settings.target.perf_warmup_rounds }}
#define NUM_MEASURE_ROUNDS {{ settings.target.perf_measure_rounds }}

{% if settings.platform != "avx2" %}
static uint64_t nanos(void) {
    struct timespec ts;
    clock_gettime(CLOCK_MONOTONIC_RAW, &ts);
    return (uint64_t)ts.tv_sec * 1e9 + ts.tv_nsec;
}
{% endif %}

int main(int argc, char **argv) {
    if (argc != 4 && argc != 5) {
        fprintf(stderr, "Usage: %s <start> <stop> <step> [logical-bytes]\nboth ends inclusive, and where each range parameter represents a number of blocks\n", argv[0]);
        return EXIT_FAILURE;
    }
    const size_t start = atoll(argv[1]);
    const size_t stop = atoll(argv[2]);
    const size_t step = atoll(argv[3]);
    const size_t buffer_len = stop * FIELD_CHUNK_SIZE;
    const size_t logical_bytes = argc == 5 ? atoll(argv[4]) : buffer_len;
    if (logical_bytes > buffer_len) {
        fprintf(stderr, "logical-bytes must fit into stop * FIELD_CHUNK_SIZE\n");
        return EXIT_FAILURE;
    }
    uint8_t *message = (uint8_t *)malloc(buffer_len);
    uint8_t *key = (uint8_t *)malloc(buffer_len);
    if (!message || !key) {
        fprintf(stderr, "Could not allocate message or key buffer. Arguments too large?\n");
        return EXIT_FAILURE;
    }
{% if settings.platform == "avx2" %}
    init_tsc();
{% endif %}
    srand(SEED);
    for (size_t i = 0; i < buffer_len; ++i) {
        if (i < logical_bytes) {
            message[i] = rand() & 255u;
            key[i] = rand() & 255u;
        } else {
            message[i] = 0;
            key[i] = 0;
        }
    }
    uint64_t sink = 0;
    for (size_t B = start; B <= stop; B += step) {
        for (size_t i = 0; i < NUM_WARMUP_ROUNDS; ++i) {
            const bigint_t res = {{func}}(message, key, B);
            sink ^= res.limb0;
        }

        double best_sample = 1ull << 52ull;
        for (size_t i = 0; i < NUM_MEASURE_ROUNDS; ++i) {
{% if settings.platform == "avx2" %}
            const TIMESTAMP start = start_tsc();
{% else %}
            const uint64_t start = nanos();
{% endif %}
            const bigint_t res = {{func}}(message, key, B);
            sink ^= res.limb0;
{% if settings.platform == "avx2" %}
            const double sample = (double)stop_tsc(start);
{% else %}
            const uint64_t end = nanos();
            const double sample = (double)(end - start) * PROC_FREQUENCY;
{% endif %}
            best_sample = sample < best_sample ? sample : best_sample;
        }
        const size_t reported_bytes = argc == 5 ? logical_bytes : B * (size_t)FIELD_CHUNK_SIZE;
        printf("{\"module\":\"{{module_name}}\",\"function\":\"{{func}}\",\"B\":%zu,\"cycles\":%.0f,\"bytes\":%zu}\n", B, best_sample, reported_bytes);

    }

    free(message);
    free(key);
    fprintf(stderr, "", sink);
    return EXIT_SUCCESS;
}
