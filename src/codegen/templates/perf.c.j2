#include <stddef.h>
#include <stdint.h>
#include <stdio.h>
#include <stdlib.h>
#include <string.h>

{% if settings.platform == "neon" -%}
#include "../measurements/vct_arm.h"
#define CPU_FREQ_GHZ 4.05
#define CPU_FREQ_HZ (CPU_FREQ_GHZ*1e9)
{% elif settings.platform == "avx2" -%}
#include "../measurements/tsc_x86.h"
{% else -%}
INVALID PLATFORM
{% endif %}

#include "datastructures.h"
#include "{{module_name}}.h"

#define SEED 42
#define NUM_WARMUP_ROUNDS 15
#define NUM_MEASURE_ROUNDS 15
// Adaptive # of samples (reps) taken per measuring round

static int compare_doubles(const void *a, const void *b)
{
    const double x = *(const double *)a;
    const double y = *(const double *)b;

    return (x > y) - (x < y);
}


typedef enum {
    MODE_MIN = 0,
    MODE_MEDIAN = 1
} IOMode;


int main(int argc, char **argv) {
    // Input
    if (argc != 5) {
        fprintf(stderr, "Usage: %s <start> <stop> <step> <I/O-mode:min|median>\nboth ends inclusive, and where each parameter is a byte length\n", argv[0]);
        return EXIT_FAILURE;
    }

    // Parameters
    const size_t start = atoll(argv[1]);
    const size_t stop = atoll(argv[2]);
    const size_t step = atoll(argv[3]);
    IOMode mode;
    if (!strcmp(argv[4], "min")) {
        mode = MODE_MIN;
        fprintf(stderr, "MIN mode\n");
    }
    else if (!strcmp(argv[4], "median")){
        mode = MODE_MEDIAN;
        fprintf(stderr, "MEDIAN mode\n");
    }
    else {
        fprintf(stderr, "Invalid mode %s\n", argv[4]);
        return EXIT_FAILURE;
    }

    // Allocate memory
    const size_t buffer_len = stop + 500;
    uint8_t *message = (uint8_t *)calloc(buffer_len, 1);
    uint8_t *key = (uint8_t *)calloc(buffer_len, 1);
    double *measurements = (double*) malloc(NUM_MEASURE_ROUNDS * sizeof(double));
    if (!message || !key || !measurements) {
        fprintf(stderr, "Could not allocate message or key buffer. Arguments too large?\n");
        return EXIT_FAILURE;
    }
    srand(SEED);
    for (size_t i = 0; i < buffer_len; ++i) {
        message[i] = rand() & 255u;
        key[i] = rand() & 255u;
    }
    uint64_t sink = 0;
    uint8_t output[FIELD_EXPORT_BYTES];

{% if settings.platform == "neon" -%}
    // Read VCT counter freq
    const TIMESTAMP ctr_freq_hz = get_vct_freq();
    const double target_ticks = 1e9 / (double) CPU_FREQ_HZ * ctr_freq_hz;
    fprintf(stderr, "target ticks: %f:\n", target_ticks);
{% elif settings.platform == "avx2" %}
    const double target_ticks = 1e9;
{%- endif %}

    double ticks_f_estimates[NUM_WARMUP_ROUNDS];

    // For all requested sizes
    for (size_t bytes = start; bytes <= stop; bytes += step) {
        // Adapt # of reps to target, doubles as warmup
        double reps = 100, ticksd = 0;
        for (size_t warmup_r = 0; warmup_r < NUM_WARMUP_ROUNDS; ++warmup_r) {
{% if settings.platform == "neon" %}
            const TIMESTAMP start = start_vct();
{% elif settings.platform == "avx2" %}
            const myInt64 start = start_tsc();
{% endif %}
            for (size_t r = 0; r < (size_t) reps; r++) {
                {{func}}(output, key, message, bytes);
                sink ^= output[0];
            }
{% if settings.platform == "neon" %}
            const TIMESTAMP ticks = stop_vct(start);
{% elif settings.platform == "avx2" %}
            const myInt64 ticks = stop_tsc(start);
{% endif %}
            ticksd = (double) ticks;
            ticks_f_estimates[warmup_r] = ticksd / reps;
            reps *= target_ticks / ticksd;

        }
        qsort(ticks_f_estimates, NUM_WARMUP_ROUNDS, sizeof(ticks_f_estimates[0]), compare_doubles);
        const double ticks_f_median = ticks_f_estimates[NUM_WARMUP_ROUNDS / 2];
        reps = target_ticks / ticks_f_median;

        double min_cycles = 1ull << 52ull;
        for (size_t i = 0; i < NUM_MEASURE_ROUNDS; ++i) {
            // Start timer
{% if settings.platform == "neon" %}
            const TIMESTAMP start = start_vct();
{% elif settings.platform == "avx2" %}
            const myInt64 start = start_tsc();
{% endif %}
            for (size_t j = 0; j < reps; ++j) {
                // Function call
                {{func}}(output, key, message, bytes);
                // Consume output
                sink ^= output[0];
                // Stop timer
            }
            // Stop timer, estimate cycles
{% if settings.platform == "neon" %}
            const TIMESTAMP sample = stop_vct(start);
            const double cycles = (double)sample / reps / ctr_freq_hz * CPU_FREQ_HZ;
{% elif settings.platform == "avx2" %}
            const myInt64 sample = stop_tsc(start);
            const double cycles = (double)sample / reps;
{% endif %}

            // Save result, update minimum
            measurements[i] = cycles;
            min_cycles = cycles < min_cycles ? cycles : min_cycles;
        }

        // Output
        if (mode == MODE_MIN) {
            printf("%.0f\n", min_cycles);
        } else if (mode == MODE_MEDIAN) {
            qsort(measurements, NUM_MEASURE_ROUNDS, sizeof(measurements[0]), compare_doubles);
            printf("%.0f\n", measurements[NUM_MEASURE_ROUNDS / 2]);
        }
        fflush(stdout);

        // Log
        {# fprintf(stderr, "%f reps %f ticks\n", reps, measurements[NUM_MEASURE_ROUNDS / 2] * reps / CPU_FREQ_HZ * ctr_freq_hz); #}

    }

    free(message);
    free(key);
    free(measurements);
    fprintf(stderr, "", sink);
    return EXIT_SUCCESS;
}
