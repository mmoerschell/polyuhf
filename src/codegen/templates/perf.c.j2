#include <stddef.h>
#include <stdint.h>
#include <stdio.h>
#include <stdlib.h>
{% if settings.platform == "avx2" %}
#include "tsc_x86.h"
{% else %}
#include <time.h>
{% endif %}

#include "datastructures.h"
#include "{{module_name}}.h"

{% if settings.platform != "avx2" %}
#define PROC_FREQUENCY 4.05
{% endif %}
#define SEED 42
#define NUM_WARMUP_ROUNDS 1000
#define NUM_MEASURE_ROUNDS 9000

{% if settings.platform != "avx2" %}
static uint64_t nanos(void) {
    struct timespec ts;
    clock_gettime(CLOCK_MONOTONIC_RAW, &ts);
    return (uint64_t)ts.tv_sec * 1e9 + ts.tv_nsec;
}
{% endif %}

int main(int argc, char **argv) {
    if (argc != 4) {
        fprintf(stderr, "Usage: %s <start> <stop> <step>\nboth ends inclusive, and where each parameter is a byte length\n", argv[0]);
        return EXIT_FAILURE;
    }
    const size_t start = atoll(argv[1]);
    const size_t stop = atoll(argv[2]);
    const size_t step = atoll(argv[3]);
    const size_t buffer_len = stop + 100;
    uint8_t *message = (uint8_t *)malloc(buffer_len);
    uint8_t *key = (uint8_t *)malloc(buffer_len);
    if (!message || !key) {
        fprintf(stderr, "Could not allocate message or key buffer. Arguments too large?\n");
        return EXIT_FAILURE;
    }
{% if settings.platform == "avx2" %}
    init_tsc();
{% endif %}
    srand(SEED);
    for (size_t i = 0; i < buffer_len; ++i) {
        message[i] = rand() & 255u;
        key[i] = rand() & 255u;
    }
    uint64_t sink = 0;
    uint8_t output[FIELD_EXPORT_BYTES];
    for (size_t bytes = start; bytes <= stop; bytes += step) {
        for (size_t i = 0; i < NUM_WARMUP_ROUNDS; ++i) {
            {{func}}(output, key, message, bytes);
            sink ^= output[0];
        }

        double best_sample = 1ull << 52ull;
        for (size_t i = 0; i < NUM_MEASURE_ROUNDS; ++i) {
{% if settings.platform == "avx2" %}
            const TIMESTAMP start = start_tsc();
{% else %}
            const uint64_t start = nanos();
{% endif %}
            {{func}}(output, key, message, bytes);
            sink ^= output[0];
{% if settings.platform == "avx2" %}
            const double sample = (double)stop_tsc(start);
{% else %}
            const uint64_t end = nanos();
            const double sample = (double)(end - start) * PROC_FREQUENCY;
{% endif %}
            best_sample = sample < best_sample ? sample : best_sample;
        }
        {# printf("{\"module\":\"{{module_name}}\",\"function\":\"{{func}}\",\"field_pi\":%zu,\"field_theta\":%zu,\"cycles\":%.0f,\"bytes\":%zu}\n", (size_t)FIELD_PI, (size_t)FIELD_THETA, best_sample, bytes); #}
        printf("%.0f\n", best_sample);

    }

    free(message);
    free(key);
    fprintf(stderr, "", sink);
    return EXIT_SUCCESS;
}
