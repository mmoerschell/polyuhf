#include <stddef.h>
#include <stdint.h>
#include <stdio.h>
#include <stdlib.h>

{% if settings.platform == "neon" -%}
#include "../measurements/vct_arm.h"
{% elif settings.platform == "avx2" -%}
#include "../measurements/tsc_x86.h"
{% else -%}
INVALID PLATFORM
{% endif %}

#include "datastructures.h"
#include "{{module_name}}.h"

#define SEED 42
#define NUM_WARMUP_ROUNDS 1000
#define NUM_MEASURE_ROUNDS 2000
// Multiple samples (reps) taken per measuring round, and divided

// TODO put these in TOML
#define CPU_FREQ_HZ 4.05e9
// on avx2: 
//#define CTR_FREQ_HZ ...


{% if settings.platform not in ["neon", "avx2"] %}
static uint64_t nanos(void) {
    struct timespec ts;
    clock_gettime(CLOCK_MONOTONIC_RAW, &ts);
    return (uint64_t)ts.tv_sec * 1e9 + ts.tv_nsec;
}
{% endif %}

int main(int argc, char **argv) {
    // Input
    if (argc != 4) {
        fprintf(stderr, "Usage: %s <start> <stop> <step>\nboth ends inclusive, and where each parameter is a byte length\n", argv[0]);
        return EXIT_FAILURE;
    }

    // Parameters
    const size_t start = atoll(argv[1]);
    const size_t stop = atoll(argv[2]);
    const size_t step = atoll(argv[3]);

    // Allocate memory
    const size_t buffer_len = stop + 500;
    uint8_t *message = (uint8_t *)malloc(buffer_len);
    uint8_t *key = (uint8_t *)malloc(buffer_len);
    if (!message || !key) {
        fprintf(stderr, "Could not allocate message or key buffer. Arguments too large?\n");
        return EXIT_FAILURE;
    }
    srand(SEED);
    for (size_t i = 0; i < buffer_len; ++i) {
        message[i] = rand() & 255u;
        key[i] = rand() & 255u;
    }
    uint64_t sink = 0;
    uint8_t output[FIELD_EXPORT_BYTES];

{% if settings.platform == "neon" -%}
    const TIMESTAMP CTR_FREQ_HZ = get_vct_freq();
{%- endif %}

    // For all requested sizes
    for (size_t bytes = start; bytes <= stop; bytes += step) {
        // Dynamically adapt # of reps to target roughly 200ms
        double target_ticks = CTR_FREQ_HZ / 5000;
        size_t reps = 1;
        size_t warmup_r;
        for (warmup_r = 0; warmup_r < NUM_WARMUP_ROUNDS; ++warmup_r) {
{% if settings.platform == "neon" %}
            const TIMESTAMP start = start_vct();
{% elif settings.platform == "avx2" %}
            const myInt64 start = start_tsc();
{% endif %}
            for (size_t r = 0; r < reps; r++) {
                {{func}}(output, key, message, bytes);
                sink ^= output[0];
            }
{% if settings.platform == "neon" %}
            const TIMESTAMP ticks = stop_vct(start);
{% elif settings.platform == "avx2" %}
            const myInt64 ticks = stop_tsc(start);
{% endif %}
            if (ticks >= target_ticks || reps >= (1u << 20)) {
                break;
            }
            reps *= 2;
        }
        for (; warmup_r < NUM_WARMUP_ROUNDS; ++warmup_r) {
            {{func}}(output, key, message, bytes);
            sink ^= output[0];
        }
        printf("Using batch size of %zu\n", reps);

        double min_cycles = 1ull << 52ull;
        for (size_t i = 0; i < NUM_MEASURE_ROUNDS; ++i) {
            // Start timer
{% if settings.platform == "neon" %}
            const TIMESTAMP start = start_vct();
{% elif settings.platform == "avx2" %}
            const myInt64 start = start_tsc();
{% endif %}
            for (size_t j = 0; j < reps; ++j) {
                // Function call
                {{func}}(output, key, message, bytes);
                // Consume output
                sink ^= output[0];
                // Stop timer
            }
{% if settings.platform == "neon" %}
            const TIMESTAMP sample = stop_vct(start);
{% elif settings.platform == "avx2" %}
            const myInt64 sample = stop_tsc(start);
{% endif %}
            // Estimate cycles
            const double cycles = (double)sample / (double)reps / CTR_FREQ_HZ * CPU_FREQ_HZ;

            // Determine minimum
            min_cycles = cycles < min_cycles ? cycles : min_cycles;
        }
        {# printf("{\"module\":\"{{module_name}}\",\"function\":\"{{func}}\",\"field_pi\":%zu,\"field_theta\":%zu,\"cycles\":%.0f,\"bytes\":%zu}\n", (size_t)FIELD_PI, (size_t)FIELD_THETA, min_cycles, bytes); #}
        printf("%.0f\n", min_cycles);

    }

    free(message);
    free(key);
    fprintf(stderr, "", sink);
    return EXIT_SUCCESS;
}
