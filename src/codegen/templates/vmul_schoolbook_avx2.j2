/* {{ dst }} = vmul {{ lhs }} {{ rhs }} */
{% macro madd(acc, left, right) -%}
_mm256_add_epi64({{ acc }}, _mm256_mul_epu32({{ left }}, {{ right }}))
{%- endmacro %}
{% macro madd_kappa(acc, left, right) -%}
_mm256_add_epi64(
    {{ acc }},
    _mm256_mul_epu32(
        _mm256_mul_epu32({{ left }}, _mm256_set1_epi64x((long long){{ settings.kappa }}ull)),
        {{ right }}
    )
)
{%- endmacro %}
{% for i in range(settings.limbs) %}
{% for j in range(i + 1) %}{{ dst }}.limb{{ i }} = {{ madd(dst ~ ".limb" ~ i, lhs ~ ".limb" ~ j, rhs ~ ".limb" ~ (i - j)) }};
{% endfor %}

{% for j in range(i + 1, settings.limbs) %}{{ dst }}.limb{{ i }} = {{ madd_kappa(dst ~ ".limb" ~ i, lhs ~ ".limb" ~ j, rhs ~ ".limb" ~ (settings.limbs + i - j)) }};
{% endfor %}
{% endfor %}
