{% for i in range(n_bytes) %}{{ dst }}[{{ i }}]
    = (uint8_t)({{ src }}.limb{{ 8 * i // settings.lambda_ }} >> ({{ 8 * i % settings.lambda_ }}))
    {% if 8 * i // settings.lambda_ + 1 < settings.limbs %} | (uint8_t)({{ src }}.limb{{ 8 * i // settings.lambda_ + 1}} << ({{ settings.lambda_ - (8 * i % settings.lambda_ )}})){% endif %};
{% endfor %}
